          },
          "watch_interval_seconds": {
            "type": "number",
            "description": "Sampling interval in seconds when start_live_session triggers runtime watching."
          },
          "watch_samples": {
            "type": "integer",
            "description": "Number of runtime samples to capture when start_live_session triggers runtime watching."
