          "content": {
            "type": "string",
            "description": "Announcement content for update_live_announcement."
          },
          "transient_grace_seconds": {
            "type": "number",
            "description": "Grace window for transient stop/start settling in live_health_check."
          },
          "announcement": {
            "type": "string",
            "description": "Live room announcement/news content to apply before start."
          },
          "title": {
            "type": "string",
            "description": "Live-room title. Confirmed write path: POST /room/v1/Room/update with room_id + title + csrf + csrf_token."
          },
          "use_session_cache": {
            "type": "boolean",
            "description": "When stopping, read/write the workspace live-session cache so another session can stop the active live and fetch StopLiveData without manually passing live_key."
          },
          "include_runtime_stats": {
            "type": "boolean",
            "description": "Include runtime stat probing when recovering a live session."
