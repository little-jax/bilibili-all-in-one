          "area_id": {
            "type": "integer",
            "description": "Optional Bilibili live area id. Defaults to current chosen area."
          },
          "obs_host": {
            "type": "string",
            "description": "OBS websocket host."
          },
          "obs_port": {
            "type": "integer",
            "description": "OBS websocket port."
          },
          "obs_password": {
            "type": "string",
            "description": "OBS websocket password."
          },
          "obs_timeout": {
            "type": "number",
            "description": "OBS websocket timeout seconds."
          },
          "reveal_sensitive": {
            "type": "boolean",
            "description": "Return full RTMP / restore target details instead of masked values."
          },
          "auto_start_obs": {
            "type": "boolean",
            "description": "When true, start OBS streaming after applying the Bilibili stream target."
          },
          "settle_seconds": {
            "type": "number",
            "description": "Seconds to wait after starting OBS before collecting follow-up status."
          },
          "restore_stream_service": {
            "type": "boolean",
            "description": "Whether stop_live_session should restore a previous OBS stream target."
          },
          "restore_service_type": {
            "type": "string",
            "description": "OBS stream service type for restore."
          },
          "restore_server": {
            "type": "string",
            "description": "Previous OBS stream server to restore."
          },
          "restore_key": {
            "type": "string",
            "description": "Previous OBS stream key to restore."
