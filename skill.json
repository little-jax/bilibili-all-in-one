    {
      "name": "bilibili_live_orchestrator",
      "description": "End-to-end Bilibili + OBS live orchestration with preflight, start, stop, and health-check flows. Sensitive RTMP data is masked by default unless reveal_sensitive=true.",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
