{
  "name": "bilibili-all-in-one",
  "description": "A comprehensive Bilibili toolkit that integrates hot trending monitoring, video downloading, video watching/playback, subtitle downloading, and video publishing capabilities into a single skill, plus QR-first login/session workflows.",
  "version": "1.0.18",
  "author": "Little Jax / Mozi A.",
  "license": "MIT-0",
  "homepage": "https://github.com/little-jax/bilibili-all-in-one",
  "repository": "https://github.com/little-jax/bilibili-all-in-one",
  "source": "https://github.com/little-jax/bilibili-all-in-one",
  "type": "code",
  "runtime": "python>=3.8",
  "entry_point": "main.py",
  "required_env_vars": [],
  "optional_env_vars": [
    "BILIBILI_SESSDATA",
    "BILIBILI_BILI_JCT",
    "BILIBILI_BUVID3",
    "BILIBILI_PERSIST",
    "BILIBILI_MESSAGE_CENTER_CONFIG"
  ],
  "install": {
    "type": "pip",
    "command": "pip install -r requirements.txt",
    "packages": [
      "httpx>=0.24.0",
      "aiohttp>=3.8.0",
      "beautifulsoup4>=4.12.0",
      "lxml>=4.9.0",
      "requests>=2.31.0",
      "qrcode[pil]>=7.4.2"
    ],
    "source": "pypi"
  },
  "env_vars": [
    {
      "name": "BILIBILI_SESSDATA",
      "type": "string",
      "description": "Bilibili SESSDATA cookie for authenticated API access. Only required for publishing and high-quality (1080p+/4K) downloads. Most features work without this.",
      "required": false,
      "sensitive": true
    },
    {
      "name": "BILIBILI_BILI_JCT",
      "type": "string",
      "description": "Bilibili bili_jct cookie (CSRF token) for write operations (upload, edit). Only required for publishing. Most features work without this.",
      "required": false,
      "sensitive": true
    },
    {
      "name": "BILIBILI_BUVID3",
      "type": "string",
      "description": "Bilibili buvid3 cookie for device identification in authenticated sessions.",
      "required": false,
      "sensitive": true
    },
    {
      "name": "BILIBILI_PERSIST",
      "type": "string",
      "description": "Set to '1', 'true', or 'yes' to enable automatic credential persistence. When enabled, credentials are saved to .credentials.json (0600 permissions) and auto-loaded on next startup. Default: disabled (in-memory only).",
      "required": false,
      "sensitive": false
    },
    {
      "name": "BILIBILI_MESSAGE_CENTER_CONFIG",
      "type": "string",
      "description": "Optional path override for the message-center config. Default active config is ~/.openclaw/workspace/bilibili-message-center.json and the skill-local config/message-center.example.json is only a template.",
      "required": false,
      "sensitive": false
    }
  ],
  "credentials": {
    "primary_credential": "BILIBILI_SESSDATA",
    "credential_type": "full_session_cookies",
    "credential_required_for": "Only the Publisher module (upload/edit/schedule/draft) and high-quality downloads (1080p+/4K) require credentials. All other features (hot monitoring, standard downloads, subtitles, danmaku, stats) work WITHOUT any credentials.",
    "credential_scope_warning": "These are full browser session cookies (not limited API keys). Providing them grants the skill broad access to your Bilibili account. Use a test/throwaway account.",
    "storage": "in-memory by default. Set persist=True (or env BILIBILI_PERSIST=1) to auto-save/load credentials from .credentials.json with 0600 permissions. Persistence can also be toggled at runtime via auth.persist property.",
    "security_notes": [
      "Credentials are NOT persisted to disk by default. Persistence must be explicitly opted-in via persist=True or BILIBILI_PERSIST=1.",
      "Prefer passing credentials via environment variables or in-memory parameters.",
      "All API requests go to official Bilibili endpoints over HTTPS.",
      "Use a test/throwaway Bilibili account for evaluation purposes.",
      "These are full session cookies — treat them as highly sensitive. They grant broad account access, not just limited API scope."
    ]
  },
  "network": {
    "protocol": "HTTPS only",
    "allowed_domains": [
      "api.bilibili.com",
      "member.bilibili.com",
      "upos-sz-upcdnbda2.bilivideo.com",
      "www.bilibili.com"
    ],
    "third_party_telemetry": false,
    "analytics": false
  },
  "files": [
    ".gitignore",
    "LICENSE",
    "README.md",
    "config/message-center.example.json",
    "main.py",
    "requirements.txt",
    "skill.json",
    "skill.md",
    "src/__init__.py",
    "src/auth.py",
    "src/auth_client.py",
    "src/downloader.py",
    "src/hot_monitor.py",
    "src/player.py",
    "src/publisher.py",
    "src/subtitle.py",
    "src/utils.py",
    "src/watcher.py"
  ],
