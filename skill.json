            "type": "boolean",
            "description": "Whether start_live_session should clear the runtime JSONL log before auto-watching."
          },
          "watch_include_overview": {
            "type": "boolean",
            "description": "Whether start_live_session auto-watch should include the Bilibili Overview payload on each sample."
